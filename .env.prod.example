# Wajib diisi. Generate dengan: openssl rand -hex 32
SESSION_SECRET=change-this-with-random-secret

# Database
DB_USER=app_user
DB_PASSWORD=change-this-database-password

# Domain frontend yang boleh akses API.
# Pisahkan dengan koma jika lebih dari satu domain.
CORS_ALLOWED_ORIGINS=https://dompetku.example.com

# URL API yang dipakai browser.
# Kosongkan agar frontend memakai /api dan diproxy oleh nginx container frontend.
# Isi hanya jika backend punya URL publik terpisah, misalnya https://api.dompetku.example.com.
VITE_API_BASE_URL=

# true jika pakai HTTPS, false jika masih HTTP/IP langsung.
COOKIE_SECURE=true

# Email admin aplikasi. Pisahkan dengan koma jika lebih dari satu.
ADMIN_EMAILS=admin@example.com
